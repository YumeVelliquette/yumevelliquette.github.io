<script>
  // Case study toggle — only show detail matching current lang
  function toggleCase(btn) {
    const card = btn.closest('.exp-card');
    const lang = document.body.className.replace('lang-', '');
    const detail = card.querySelector('.case-detail.' + lang);
    const allDetails = card.querySelectorAll('.case-detail');
    const isOpen = btn.classList.contains('open');
    allDetails.forEach(d => d.classList.remove('open'));
    if (!isOpen && detail) detail.classList.add('open');
    btn.classList.toggle('open', !isOpen);
  }

  // Lang toggle
  function setLang(lang) {
    document.body.className = 'lang-' + lang;
    document.getElementById('btn-en').classList.toggle('active', lang === 'en');
    document.getElementById('btn-ja').classList.toggle('active', lang === 'ja');
    // Close all open case details on lang switch
    document.querySelectorAll('.case-detail.open').forEach(d => d.classList.remove('open'));
    document.querySelectorAll('.read-more-btn.open').forEach(b => b.classList.remove('open'));
  }

  // Scroll fade-in
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('on');
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.fi').forEach(el => obs.observe(el));
</script>
